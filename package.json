{
  "name": "claude-status",
  "version": "0.1.0",
  "description": "Tray app showing Claude Code daily/weekly cost usage",
  "main": "main.js",
  "author": "yingfu",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node --test test/**/*.test.js",
    "icon": "node scripts/gen-icon.js",
    "pack:dir": "electron-builder --dir",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:all": "electron-builder -mwl"
  },
  "build": {
    "appId": "com.claudestatus.app",
    "productName": "Claude Status",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "settings-preload.js",
      "lib/**/*",
      "renderer/**/*",
      "assets/**/*",
      "package.json",
      "!**/*.md",
      "!test/**/*",
      "!docs/**/*",
      "!config.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Utility",
      "maintainer": "yingfu <yingfu@example.com>"
    }
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "electron-builder": "^24.13.3",
    "jimp": "^0.22.12",
    "png-to-ico": "^3.0.1"
  }
}
